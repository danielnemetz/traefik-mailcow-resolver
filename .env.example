k# Traefik – Beispiel. cp .env.example .env und anpassen. .env nicht versionieren.
IONOS_API_KEY=dein-ionos-api-key
ACME_EMAIL=admin@example.com
MAIN_DOMAIN=mail.example.com
BASE_DOMAIN=example.com
BASE_DOMAIN_ESCAPED=example\\.com
TRAEFIK_DATA_DIR=/opt/traefik/data
MAILCOW_SSL_PATH=/opt/mailcow-dockerized/data/assets/ssl
MAILCOW_SSL_EXAMPLE_PATH=/opt/mailcow-dockerized/data/assets/ssl-example
TCD_RESTART_LABEL=com.docker.compose.project=mailcowdockerized

